
# ==== Pinecone (use your existing serverless index) ====
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX_NAME=rabbitt-ai
# Prefer host to ensure you connect to the exact index you mentioned
PINECONE_HOST=https://rabbitt-ai-lkp2esr.svc.aped-4627-b74a.pinecone.io
PINECONE_NAMESPACE=influencers

# ==== NVIDIA / LLM ====
NVIDIA_API_KEY=your_nvidia_key
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024
LLM_MODEL=meta/llama-3.1-70b-instruct

# (Optional) OpenAI-compatible override (e.g., GPT-5)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-5

# ==== MongoDB ====
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster-host>/?retryWrites=true&w=majority
MONGODB_DB=rabbitt-dbms
MONGODB_COLLECTION=rabbitt-collections
